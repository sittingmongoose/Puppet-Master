#!/usr/bin/env bash
# Mock cursor-agent CLI for integration testing

# Handle --version flag
if [[ "$1" == "--version" ]]; then
  echo "cursor-agent version 1.0.0"
  exit 0
fi

# Handle --help flag
if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
  echo "cursor-agent - AI-powered code editor"
  echo ""
  echo "Usage: cursor-agent [options]"
  echo ""
  echo "Options:"
  echo "  -p, --print          Print mode (non-interactive)"
  echo "  --model <model>      Specify model to use"
  echo "  --version            Show version"
  echo "  --help               Show this help"
  exit 0
fi

# Handle execution (non-interactive mode with -p flag)
# Read prompt from stdin or environment
PROMPT="${CURSOR_PROMPT:-}"
if [[ -z "$PROMPT" ]]; then
  # Read from stdin
  while IFS= read -r line; do
    PROMPT="${PROMPT}${line}\n"
  done
fi

# Generate a session ID (format: PM-YYYY-MM-DD-HH-MM-SS-NNN)
SESSION_ID="PM-$(date +%Y-%m-%d-%H-%M-%S)-001"

# Output response with completion signal
# Default to COMPLETE unless MOCK_CURSOR_SIGNAL is set
SIGNAL="${MOCK_CURSOR_SIGNAL:-COMPLETE}"

echo "Processing request..."
echo "Session ID: ${SESSION_ID}"
echo "Tokens used: 1234"
echo "Output: Task completed successfully"
echo "<ralph>${SIGNAL}</ralph>"

exit 0
