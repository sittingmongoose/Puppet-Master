#!/usr/bin/env bash
# Mock claude CLI for integration testing

# Handle --version flag
if [[ "$1" == "--version" ]]; then
  echo "claude version 1.0.0"
  exit 0
fi

# Handle --help flag
if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
  echo "claude - Claude AI assistant"
  echo ""
  echo "Usage: claude [options]"
  echo ""
  echo "Options:"
  echo "  -p, --prompt <text>   Prompt text (non-interactive mode)"
  echo "  --model <model>       Specify model to use"
  echo "  --max-turns <n>        Maximum conversation turns"
  echo "  --output-format <fmt> Output format (json, stream-json, text)"
  echo "  --version             Show version"
  echo "  --help                Show this help"
  exit 0
fi

# Handle execution
# Claude uses -p flag with prompt as argument, or reads from stdin
PROMPT=""
if [[ "$1" == "-p" ]] && [[ -n "$2" ]]; then
  PROMPT="$2"
elif [[ "$1" == "--prompt" ]] && [[ -n "$2" ]]; then
  PROMPT="$2"
else
  # Read from stdin
  while IFS= read -r line; do
    PROMPT="${PROMPT}${line}\n"
  done
fi

# Generate a session ID (format: PM-YYYY-MM-DD-HH-MM-SS-NNN)
SESSION_ID="PM-$(date +%Y-%m-%d-%H-%M-%S)-001"

# Output response with completion signal
# Default to COMPLETE unless MOCK_CLAUDE_SIGNAL is set
SIGNAL="${MOCK_CLAUDE_SIGNAL:-COMPLETE}"

echo "Processing request..."
echo "Session ID: ${SESSION_ID}"
echo "tokens: 1234"
echo "Output: Task completed successfully"
echo "<ralph>${SIGNAL}</ralph>"

exit 0
