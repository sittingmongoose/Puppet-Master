{
  "name": "puppet-master",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "puppet-master": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gui": "tsx src/gui/start-gui.ts",
    "gui:dev": "npm --prefix src/gui/react run dev",
    "gui:build": "npm --prefix src/gui/react run build",
    "gui:typecheck": "npm --prefix src/gui/react run typecheck",
    "build:win": "tsx scripts/build-installer.ts --platform win32 --arch x64",
    "build:mac": "tsx scripts/build-installer.ts --platform darwin --arch arm64",
    "build:linux": "tsx scripts/build-installer.ts --platform linux --arch x64",
    "build:all": "tsx scripts/build-installer.ts",
    "check:platform": "tsx scripts/check-platform-compatibility.ts",
    "validate:contracts": "tsx scripts/validate-contracts.ts",
    "validate:integration-paths": "tsx scripts/validate-integration-paths.ts",
    "detect:dead-code": "tsx scripts/detect-dead-code.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.0",
    "@upstash/context7-mcp": "^2.1.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.13",
    "@openai/codex-sdk": "^0.91.0",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.18.0",
    "js-yaml": "^4.1.0",
    "mammoth": "^1.11.0",
    "open": "^10.1.0",
    "pdf-parse": "^1.1.4",
    "playwright": "^1.40.0",
    "semver": "^7.7.3",
    "ws": "^8.14.0"
  }
}
