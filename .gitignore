node_modules/
dist/
coverage/

# Rust build output
**/target/

npm-debug.log*
yarn-error.log*
.DS_Store

# Local CLI agent state (may contain credentials)
.cache/
.npm/

# Claude-specific: ignore credentials, state, and debug files
.claude/.credentials.json
.claude/_state/
.claude/debug/
.claude/.fuse_hidden*

# Codex-specific: ignore auth, sessions, and runtime data
.codex/auth.json
.codex/sessions/
.codex/archived_sessions/

# Cursor-specific: no sensitive files to ignore (commands/ can be tracked)

# Installer staging (build output)
installer-work/

# Test artifacts
.test-quota-*
.test-init-*
.test-cache/
.test-*/

# Evidence screenshots are large/noisy; keep other evidence (logs, reports, traces) tracked.
.puppet-master/evidence/screenshots/*.png
.puppet-master/evidence/screenshots/*.jpg
.puppet-master/evidence/screenshots/*.jpeg
.puppet-master/evidence/screenshots/*.webp

# Project-local runtime state that should not be committed (volatile / machine-specific).
.puppet-master/gui-token.txt
.puppet-master/events.db
.puppet-master/events.db-shm
.puppet-master/events.db-wal
.puppet-master/checkpoints/
.puppet-master/capabilities/
.puppet-master/usage/usage.jsonl
.puppet-master/prd.json.backup*
.puppet-master/prd.json.tmp.*
.puppet-master/worktrees/

# Local dev server logs (not evidence)
gui.log

# Secrets (local-only; never commit)
.env
.env.*
!.env.example

# Local configuration files (may contain sensitive local settings)
**/local.json
local.json

# Local notes / docs (Reference/RalphInfo has deep paths + long .snap names that exceed Windows MAX_PATH when zipping)
/RalphInfo/
/Reference/RalphInfo/
/GBC\ Shader/

# UsageTracker in-memory test artifact (invalid filename on Windows)
:memory:
