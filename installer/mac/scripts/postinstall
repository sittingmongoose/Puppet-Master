#!/bin/sh
set -eu

APP_BUNDLE="/Applications/Puppet Master.app"

# Stop any running Puppet Master processes to avoid file-in-use issues
echo "Checking for running Puppet Master processes..."
# Kill by process name
pkill -9 -f "Puppet Master" 2>/dev/null || true
pkill -9 -f "puppet-master" 2>/dev/null || true
# Kill node processes running from the app bundle
pkill -9 -f "${APP_BUNDLE}" 2>/dev/null || true
# Wait for processes to fully exit
sleep 2

# Verify .app bundle was installed
if [ ! -d "${APP_BUNDLE}" ]; then
  echo "ERROR: Expected app bundle missing: ${APP_BUNDLE}" 1>&2
  echo "Expected app bundle missing: ${APP_BUNDLE}" > /tmp/puppet-master-install-err.log 2>/dev/null || true
  exit 1
fi

# Verify Contents/Resources/puppet-master exists
RESOURCES_DIR="${APP_BUNDLE}/Contents/Resources"
INSTALL_ROOT="${RESOURCES_DIR}/puppet-master"
if [ ! -d "${INSTALL_ROOT}" ]; then
  echo "ERROR: Expected install root missing: ${INSTALL_ROOT}" 1>&2
  echo "Expected install root missing: ${INSTALL_ROOT}" > /tmp/puppet-master-install-err.log 2>/dev/null || true
  exit 1
fi

# Fix npm/npx/corepack launchers to use bundled Node runtime
# This ensures they work after installation (previous CI-built symlinks are broken)
NODE_BIN="${INSTALL_ROOT}/node/bin"
NODE_EXE="${NODE_BIN}/node"
NPM_CLI="${INSTALL_ROOT}/node/lib/node_modules/npm/bin/npm-cli.js"
NPX_CLI="${INSTALL_ROOT}/node/lib/node_modules/npm/bin/npx-cli.js"
COREPACK_CLI="${INSTALL_ROOT}/node/lib/node_modules/corepack/dist/corepack.js"

if [ -x "${NODE_EXE}" ] && [ -d "${NODE_BIN}" ]; then
  # Remove broken symlinks from CI build
  rm -f "${NODE_BIN}/npm" "${NODE_BIN}/npx" "${NODE_BIN}/corepack" 2>/dev/null || true
  
  # Create working launchers that use the bundled Node
  if [ -f "${NPM_CLI}" ]; then
    cat > "${NODE_BIN}/npm" <<'NPMEOF'
#!/bin/sh
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NODE_EXE="$SCRIPT_DIR/node"
NPM_CLI="$SCRIPT_DIR/../lib/node_modules/npm/bin/npm-cli.js"
exec "$NODE_EXE" "$NPM_CLI" "$@"
NPMEOF
    chmod +x "${NODE_BIN}/npm" 2>/dev/null || true
  fi
  
  if [ -f "${NPX_CLI}" ]; then
    cat > "${NODE_BIN}/npx" <<'NPXEOF'
#!/bin/sh
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NODE_EXE="$SCRIPT_DIR/node"
NPX_CLI="$SCRIPT_DIR/../lib/node_modules/npm/bin/npx-cli.js"
exec "$NODE_EXE" "$NPX_CLI" "$@"
NPXEOF
    chmod +x "${NODE_BIN}/npx" 2>/dev/null || true
  fi
  
  if [ -f "${COREPACK_CLI}" ]; then
    cat > "${NODE_BIN}/corepack" <<'COREPACKEOF'
#!/bin/sh
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NODE_EXE="$SCRIPT_DIR/node"
COREPACK_CLI="$SCRIPT_DIR/../lib/node_modules/corepack/dist/corepack.js"
exec "$NODE_EXE" "$COREPACK_CLI" "$@"
COREPACKEOF
    chmod +x "${NODE_BIN}/corepack" 2>/dev/null || true
  fi
fi

# Rebuild native modules (e.g. better-sqlite3) with bundled Node to ensure ABI compatibility
APP_DIR="${INSTALL_ROOT}/app"
if [ -x "${NODE_EXE}" ] && [ -f "${APP_DIR}/package.json" ]; then
  echo "Rebuilding native modules for bundled Node..."
  # Try up to 3 times with delays to handle file locks
  REBUILD_SUCCESS=0
  for i in 1 2 3; do
    if PATH="${NODE_BIN}:$PATH" "${NODE_EXE}" "${NPM_CLI}" rebuild --prefix "${APP_DIR}" 2>/dev/null; then
      REBUILD_SUCCESS=1
      break
    else
      if [ $i -lt 3 ]; then
        echo "Rebuild attempt $i failed, retrying in 2 seconds..."
        sleep 2
      fi
    fi
  done
  
  if [ $REBUILD_SUCCESS -eq 0 ]; then
    echo "Warning: Native module rebuild failed after 3 attempts. App may still work." >&2
  fi
fi

LAUNCHER="${INSTALL_ROOT}/bin/puppet-master"
if [ ! -x "${LAUNCHER}" ]; then
  echo "ERROR: Expected launcher missing or not executable: ${LAUNCHER}" 1>&2
  echo "Expected launcher missing or not executable: ${LAUNCHER}" > /tmp/puppet-master-install-err.log 2>/dev/null || true
  exit 1
fi

echo "Installed Puppet Master.app to ${APP_BUNDLE}"
echo "CLI available at ${LAUNCHER}"

# Create /usr/local/bin symlink so 'puppet-master' works from Terminal
if [ -d /usr/local/bin ]; then
  ln -sf "${LAUNCHER}" /usr/local/bin/puppet-master 2>/dev/null || true
fi

echo ""
echo "Puppet Master installed. Open from Applications or run 'puppet-master gui'."
echo "On first launch, a setup wizard will help install AI platform CLIs."
echo ""

# Auto-launch the GUI after installation only when interactive (not in CI/headless).
# In CI or headless environments, `open` fails and would cause the installer to report failure.
# Subshell + exit 0 ensures a failing open never makes postinstall exit non-zero.
if [ -z "${CI:-}" ] && [ -z "${GITHUB_ACTIONS:-}" ]; then
  CURRENT_USER=$(stat -f "%Su" /dev/console 2>/dev/null || echo "")
  if [ -n "$CURRENT_USER" ] && [ "$CURRENT_USER" != "root" ]; then
    ( sudo -u "$CURRENT_USER" open "/Applications/Puppet Master.app" 2>/dev/null; exit 0 ) &
  fi
fi

exit 0
