#!/bin/sh
# P0-G23: Post-install guidance for Linux packages
# P2-G10: Updated to include systemd service instructions

# Rebuild native modules (e.g. better-sqlite3) with bundled Node so ABI matches
ROOT="/opt/puppet-master"
if [ -x "$ROOT/node/bin/node" ] && [ -f "$ROOT/app/package.json" ]; then
  PATH="$ROOT/node/bin:$PATH" npm rebuild --prefix "$ROOT/app" 2>/dev/null || true
fi

# Update desktop database so the .desktop file is picked up
if command -v update-desktop-database >/dev/null 2>&1; then
  update-desktop-database /usr/share/applications 2>/dev/null || true
fi

echo ""
echo "Puppet Master installed. Find 'Puppet Master' in your application menu,"
echo "or run 'puppet-master gui' from the terminal."
echo "On first launch, a setup wizard will help install AI platform CLIs."
echo ""

# Notify user (optional; must not cause install to fail)
if command -v notify-send >/dev/null 2>&1; then
  ( notify-send "Puppet Master" "Installation complete. Find 'Puppet Master' in your application menu." -i /opt/puppet-master/puppet-master.png 2>/dev/null ) || true
fi
