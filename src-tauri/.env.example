# Tauri Desktop Configuration
# Copy to .env and customize as needed

# GUI Server URL
# Default: http://127.0.0.1:3847
# PUPPET_MASTER_URL=http://127.0.0.1:3847

# Alternative: Connect to remote server
# PUPPET_MASTER_URL=http://192.168.1.100:3847

# Development: Use different port
# GUI_PORT=4000
# PUPPET_MASTER_URL=http://127.0.0.1:4000
