{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pm.project_contracts_index.schema.v1",
  "title": "Puppet Master Project Contract Pack Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "generated_at_utc", "contracts"],
  "properties": {
    "schema_id": {"type": "string", "const": "pm.project_contracts_index.schema.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/contract_entry"}
    }
  },
  "$defs": {
    "contract_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_id", "kind", "path", "sha256"],
      "properties": {
        "contract_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^ProjectContract:"
        },
        "kind": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
        "description": {"type": "string"},
        "anchors": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}

