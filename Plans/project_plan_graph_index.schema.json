{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pm.project-plan-graph-index.v1",
  "title": "Puppet Master Project Plan Graph Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "graph_id", "nodes", "entrypoints", "validation"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"type": "string", "minLength": 1},
    "graph_id": {"type": "string", "minLength": 1},
    "created_at_utc": {"type": "string"},
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "path", "sha256"],
        "properties": {
          "node_id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
          "subgraph": {"type": "string"},
          "depends_on": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index_schema_id", "node_schema_id", "targets"],
      "properties": {
        "index_schema_id": {"type": "string", "const": "pm.project-plan-graph-index.v1"},
        "node_schema_id": {"type": "string", "const": "pm.project-plan-node.v1"},
        "targets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["acceptance_manifest", "contracts_index"],
          "properties": {
            "acceptance_manifest": {"type": "string", "minLength": 1},
            "contracts_index": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}

