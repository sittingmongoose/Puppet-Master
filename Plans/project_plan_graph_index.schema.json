{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pm.project-plan-graph-index.v1",
  "title": "Puppet Master Project Plan Graph Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "graph_id",
    "nodes",
    "entrypoints",
    "execution_ordering",
    "validation"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"type": "string", "minLength": 1},
    "graph_id": {"type": "string", "minLength": 1},
    "created_at_utc": {"type": "string"},
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "path", "sha256"],
        "properties": {
          "node_id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
          "subgraph": {"type": "string"},
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "execution_ordering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ready_rule",
        "selection_rule",
        "completion_rule",
        "spec_lock_source",
        "node_state_source"
      ],
      "properties": {
        "ready_rule": {
          "type": "string",
          "const": "all_blockers_done_and_spec_lock_satisfied"
        },
        "selection_rule": {
          "type": "string",
          "const": "lexicographic_node_id"
        },
        "completion_rule": {
          "type": "string",
          "const": "verifier_evidence_then_auto_done"
        },
        "spec_lock_source": {
          "type": "string",
          "const": "Plans/Spec_Lock.json"
        },
        "node_state_source": {
          "type": "string",
          "const": "plan_graph/nodes/<node_id>.json"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index_schema_id", "node_schema_id", "targets"],
      "properties": {
        "index_schema_id": {"type": "string", "const": "pm.project-plan-graph-index.v1"},
        "node_schema_id": {"type": "string", "const": "pm.project-plan-node.v1"},
        "targets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["acceptance_manifest", "contracts_index"],
          "properties": {
            "acceptance_manifest": {"type": "string", "minLength": 1},
            "contracts_index": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
