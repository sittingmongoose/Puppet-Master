{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pm.evidence.schema.v1",
  "title": "Puppet Master Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "evidence_id",
    "created_at_utc",
    "node",
    "summary",
    "commands_run",
    "tool_calls",
    "events",
    "files_changed",
    "contract_refs_satisfied",
    "reproducibility",
    "artifacts",
    "checks"
  ],
  "properties": {
    "schema_id": {"type": "string", "const": "pm.evidence.schema.v1"},
    "evidence_id": {"type": "string", "minLength": 1},
    "created_at_utc": {"type": "string", "minLength": 1},
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id"],
      "properties": {
        "node_id": {"type": "string", "minLength": 1},
        "graph_id": {"type": "string"},
        "graph_scope": {"type": "string"}
      }
    },
    "summary": {"type": "string", "minLength": 1},
    "commands_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cmd", "exit_code"],
        "properties": {
          "cmd": {"type": "string"},
          "exit_code": {"type": "integer"},
          "stdout_excerpt": {"type": "string"},
          "stderr_excerpt": {"type": "string"}
        }
      }
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool_id", "count"],
        "properties": {
          "tool_id": {"type": "string", "minLength": 1},
          "count": {"type": "integer", "minimum": 0},
          "denied_count": {"type": "integer", "minimum": 0},
          "error_count": {"type": "integer", "minimum": 0},
          "note": {"type": "string"}
        }
      }
    },
    "events": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_refs"],
      "properties": {
        "event_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "ref"],
            "properties": {
              "source": {"type": "string", "enum": ["seglog", "jsonl", "other"]},
              "ref": {"type": "string", "minLength": 1},
              "note": {"type": "string"}
            }
          }
        }
      }
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "change_type"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "change_type": {
            "type": "string",
            "enum": ["added", "modified", "deleted", "renamed"]
          },
          "additions": {"type": "integer", "minimum": 0},
          "deletions": {"type": "integer", "minimum": 0},
          "note": {"type": "string"}
        }
      }
    },
    "contract_refs_satisfied": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_ref"],
      "properties": {
        "snapshot_ref": {"type": "string", "minLength": 1},
        "note": {"type": "string"}
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": {"type": "string"},
          "sha256": {"type": "string"},
          "note": {"type": "string"}
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "result"],
        "properties": {
          "name": {"type": "string"},
          "result": {"type": "string", "enum": ["PASS", "FAIL"]},
          "details": {"type": "string"},
          "contract_refs": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
