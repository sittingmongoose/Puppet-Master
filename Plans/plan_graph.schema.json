{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pm.plan_graph.schema.v1",
  "title": "Puppet Master Self-Build Plan Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "graph_scope", "graph_id", "entrypoints", "nodes"],
  "properties": {
    "schema_id": {"type": "string", "const": "pm.plan_graph.schema.v1"},
    "graph_scope": {
      "type": "string",
      "const": "puppet-master-repo-build"
    },
    "graph_id": {"type": "string", "minLength": 1},
    "entrypoints": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_id",
          "objective",
          "contract_refs",
          "inputs",
          "outputs",
          "acceptance",
          "allowed_tools",
          "policy_mode",
          "change_budget",
          "evidence_required",
          "blockers",
          "unblocks"
        ],
        "properties": {
          "node_id": {"type": "string", "minLength": 1},
          "objective": {"type": "string", "minLength": 1},
          "contract_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "inputs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "ref"],
              "properties": {
                "kind": {"type": "string", "minLength": 1},
                "ref": {"type": "string", "minLength": 1},
                "note": {"type": "string"}
              }
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "ref"],
              "properties": {
                "kind": {"type": "string", "minLength": 1},
                "ref": {"type": "string", "minLength": 1},
                "note": {"type": "string"}
              }
            }
          },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["check_id", "commands", "expected_events"],
              "properties": {
                "check_id": {"type": "string", "minLength": 1},
                "commands": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["cmd", "expect_exit_code"],
                    "properties": {
                      "cmd": {"type": "string", "minLength": 1},
                      "cwd": {"type": "string"},
                      "expect_exit_code": {"type": "integer"}
                    }
                  }
                },
                "expected_events": {"type": "array", "items": {"type": "string"}},
                "note": {"type": "string"}
              }
            }
          },
          "allowed_tools": {"type": "array", "items": {"type": "string"}},
          "policy_mode": {"type": "string", "minLength": 1},
          "change_budget": {"type": "object"},
          "evidence_required": {
            "type": "object",
            "additionalProperties": false,
            "required": ["schema_id", "path"],
            "properties": {
              "schema_id": {"type": "string", "const": "pm.evidence.schema.v1"},
              "path": {"type": "string", "minLength": 1}
            }
          },
          "blockers": {"type": "array", "items": {"type": "string"}},
          "unblocks": {"type": "array", "items": {"type": "string"}},
          "example": {"type": "boolean"}
        }
      }
    }
  }
}
