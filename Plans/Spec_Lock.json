{
  "schema_id": "pm.spec_lock.v1",
  "platform_name": "Puppet Master",
  "locked_decisions": {
    "runtime": {
      "language": "rust",
      "end_to_end": true
    },
    "ui": {
      "toolkit": "slint",
      "toolkit_version": "1.15.1",
      "preserve_visual_identity": true,
      "layout_may_change": true,
      "legacy_toolkit": "iced"
    },
    "storage": {
      "event_log": "seglog",
      "kv_store": "redb",
      "search_index": "tantivy",
      "forbid_sqlite": true
    },
    "providers": {
      "unified_deterministic_agent_loop": true,
      "provider_facade": {
        "cursor": {
          "single_facade": true,
          "supported_transports": [
            "stream-json",
            "acp"
          ]
        },
        "claude_code": {
          "supported_transports": [
            "stream-json"
          ]
        }
      }
    },
    "github_operations": {
      "host": "github.com",
      "api_base_url": "https://api.github.com",
      "api_only": true,
      "forbid_github_cli": true
    },
    "auth_model": {
      "github_default": "oauth_device_code",
      "device_flow_scope": "repo read:user user:email read:org",
      "device_flow_no_client_secret": true
    },
    "testing_and_verification": {
      "fully_autonomous": true,
      "no_human_approval_required": true,
      "evidence_required_for_completion": true
    }
  },
  "forbidden_deps": {
    "items": [
      {
        "kind": "storage_engine",
        "id": "sqlite"
      },
      {
        "kind": "hosting_integration",
        "id": "github_cli"
      }
    ]
  },
