{
  "schema_id": "pm.spec_lock.v0",
  "platform_name": "Puppet Master",
  "github_operations": {
    "host": "github.com",
    "api_base_url": "https://api.github.com",
    "api_only": true,
    "forbid_github_cli": true
  },
  "auth_model": {
    "github_default": "oauth_device_code",
    "device_flow_scope": "repo read:user user:email read:org",
    "device_flow_no_client_secret": true
  },
  "ui": {
    "toolkit": "slint",
    "toolkit_version": "1.15.1",
    "legacy_toolkit": "iced"
  },
  "storage": {
    "event_log": "seglog",
    "kv_store": "redb",
    "search_index": "tantivy",
    "forbid_sqlite": true
  }
}
